---
/**
 * Persistent identity sidebar (CLAUDE.md §4). Sticky charcoal panel on desktop,
 * collapses to a top bar on mobile. Fully Persona-styled: framed photo + mask
 * badge, ransom-note name, numbered angular nav, accent tags, motion toggle.
 */
import RansomText from "./RansomText.astro";
import MaskEmblem from "./MaskEmblem.astro";

const nav = [
  { label: "Home", href: "/" },
  { label: "Research", href: "/research" },
  { label: "Publications", href: "/publications" },
  { label: "Presentations", href: "/presentations" },
  { label: "Resume", href: "/resume" },
];

const current = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) => (href === "/" ? current === "/" : current.startsWith(href));

const tags = ["Particle Detection", "Fusion Diagnostics", "Particle Physics"];
---

<aside class="sidebar">
  <div class="identity">
    <div class="photo-frame">
      <img
        class="photo"
        src="/profile.jpg"
        width="260"
        height="325"
        alt="Baron Li standing beside a research poster"
      />
      <MaskEmblem class="photo-badge" size="64px" />
    </div>

    <RansomText text="Baron Li" size="clamp(1.7rem, 4.5vw, 2.4rem)" class="name" label="Baron Li" />
    <p class="role"><span>Physics Researcher</span></p>
  </div>

  <ul class="tags" aria-label="Focus areas">
    {tags.map((t) => <li>{t}</li>)}
  </ul>

  <nav class="nav" aria-label="Primary">
    <ul>
      {
        nav.map((item, i) => (
          <li class:list={[{ active: isActive(item.href) }, i % 2 === 0 ? "odd" : "even"]}>
            <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
              <span class="nav-shape" aria-hidden="true" />
              <span class="nav-num" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              <span class="nav-label">{item.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="contact">
    <a href="mailto:baronjk2027@gmail.com">baronjk2027@gmail.com</a>
    <a href="https://baronli.org">baronli.org</a>
  </div>

  <button
    type="button"
    class="motion-toggle"
    data-motion-toggle
    aria-pressed="false"
    aria-label="Toggle animations"
  >
    <span class="motion-shape" aria-hidden="true"></span>
    <span class="motion-text">Motion: <strong data-motion-label>Auto</strong></span>
  </button>

  <footer class="credit">© 2026 Baron Li</footer>
</aside>

<style>
  @import "../styles/navTilt.css";

  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
    padding: 1.75rem 1.4rem;
    background:
      linear-gradient(180deg, var(--p5-gray-900) 0%, #0b0b0b 100%);
    border-right: 3px solid var(--p5-red);
    overflow-y: auto;
    overflow-x: hidden;
  }

  /* jagged red wedge down the inner edge */
  .sidebar::after {
    content: "";
    position: absolute;
    top: 0;
    right: -3px;
    width: 6px;
    height: 100%;
    background: var(--p5-red);
    clip-path: polygon(0 0, 100% 5%, 0 12%, 100% 20%, 0 30%, 100% 92%, 0 100%);
  }

  .identity {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .photo-frame {
    position: relative;
    width: 100%;
    max-width: 230px;
    transform: skewX(var(--skew-soft));
  }

  .photo {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: 50% 22%;
    border: 3px solid var(--p5-white);
    box-shadow: var(--shadow-hard);
    background: var(--p5-red-deep);
    filter: contrast(1.05) saturate(0.9);
  }

  .photo-badge {
    position: absolute;
    right: -14px;
    bottom: -14px;
    transform: skewX(calc(-1 * var(--skew-soft))) rotate(6deg);
  }

  .name {
    margin-top: 0.3rem;
  }

  .role {
    margin: 0.2rem 0 0;
    display: inline-block;
    align-self: flex-start;
    background: var(--p5-black);
    color: var(--p5-yellow);
    border: 1.5px solid var(--p5-yellow);
    transform: skewX(var(--skew));
    padding: 0.18em 0.7em;
  }
  .role span {
    display: inline-block;
    transform: skewX(calc(-1 * var(--skew)));
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.66rem;
    font-weight: 600;
  }

  .tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tags li {
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3em 0.6em;
    border: 1.5px solid var(--p5-green);
    color: var(--p5-green);
    transform: skewX(var(--skew));
  }

  .nav {
    margin-top: auto;
  }

  .nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .nav a {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.03em;
    color: var(--p5-white);
    padding: 0.12em 0.55em;
    transform: skewX(var(--skew));
    transition: color 0.15s;
    text-transform: uppercase;
  }

  .nav-num {
    position: relative;
    z-index: 1;
    font-size: 0.7rem;
    font-family: var(--font-body);
    font-weight: 600;
    color: var(--p5-red-text);
    transition: color 0.15s;
  }

  .nav-label {
    position: relative;
    z-index: 1;
    display: inline-block;
  }

  .nav-shape {
    position: absolute;
    inset: 0;
    background: var(--p5-red);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.18s var(--ease-slam);
    z-index: 0;
  }

  .nav a:hover .nav-shape,
  .nav a:focus-visible .nav-shape,
  .nav li.active a .nav-shape {
    transform: scaleX(1);
  }

  .nav a:hover,
  .nav a:focus-visible,
  .nav li.active a {
    color: var(--p5-white);
  }
  .nav a:hover .nav-num,
  .nav li.active a .nav-num {
    color: var(--p5-yellow);
  }

  /* active item gets a yellow leading tick */
  .nav li.active a::before {
    content: "";
    position: absolute;
    left: -10px;
    top: 50%;
    width: 6px;
    height: 70%;
    background: var(--p5-yellow);
    transform: translateY(-50%);
    z-index: 1;
  }

  .contact {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-size: 0.78rem;
    word-break: break-word;
  }

  .contact a {
    color: var(--p5-gray-400);
  }
  .contact a:hover,
  .contact a:focus-visible {
    color: var(--p5-green);
  }

  /* ---- Motion toggle ---- */
  .motion-toggle {
    position: relative;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--p5-white);
    background: transparent;
    border: 1.5px solid var(--p5-white);
    padding: 0.4em 0.7em;
    transform: skewX(var(--skew));
    cursor: pointer;
    overflow: hidden;
    transition: color 0.15s, border-color 0.15s;
  }

  .motion-shape {
    position: absolute;
    inset: 0;
    background: var(--p5-yellow);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.18s var(--ease-slam);
    z-index: 0;
  }

  .motion-text {
    position: relative;
    z-index: 1;
    transform: skewX(calc(-1 * var(--skew)));
  }
  .motion-text strong {
    font-weight: 600;
    color: var(--p5-yellow);
  }

  .motion-toggle:hover .motion-shape,
  .motion-toggle:focus-visible .motion-shape,
  .motion-toggle[aria-pressed="true"] .motion-shape {
    transform: scaleX(1);
  }
  .motion-toggle:hover,
  .motion-toggle:focus-visible,
  .motion-toggle[aria-pressed="true"] {
    color: var(--p5-black);
    border-color: var(--p5-yellow);
  }
  .motion-toggle[aria-pressed="true"] .motion-text strong {
    color: var(--p5-black);
  }

  .credit {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--p5-gray-400);
  }

  /* ---- Mobile: sidebar becomes a top bar ---- */
  @media (max-width: 800px) {
    .sidebar {
      position: static;
      height: auto;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.7rem 1rem;
      border-right: none;
      border-bottom: 3px solid var(--p5-red);
      padding: 1rem 1.1rem;
    }
    .sidebar::after {
      display: none;
    }
    .identity {
      flex-direction: row;
      align-items: center;
      gap: 0.75rem;
    }
    .photo-frame {
      width: 54px;
      flex: none;
    }
    .photo-badge {
      display: none;
    }
    .name {
      font-size: 1.2rem;
    }
    .tags {
      width: 100%;
      order: 3;
    }
    .nav {
      margin-top: 0;
      width: 100%;
      order: 4;
    }
    .nav ul {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .nav a {
      font-size: 1.05rem;
    }
    .nav li.active a::before {
      display: none;
    }
    .contact {
      order: 5;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.25rem 1rem;
      width: 100%;
    }
    .motion-toggle {
      order: 6;
    }
    .credit {
      order: 7;
    }
  }
</style>
