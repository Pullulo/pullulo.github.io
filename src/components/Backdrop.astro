---
/**
 * Backdrop — the fixed, chaotic Persona-5 background that lives behind all page
 * content. Layered charcoal base + jagged red shards + outline stars + halftone.
 * Purely decorative (aria-hidden, pointer-events:none); kept dark in the centre
 * so content panels stay readable.
 */
---

<div class="backdrop" aria-hidden="true">
  <svg class="shards" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice">
    <!-- big red shards anchored to the corners -->
    <polygon points="0,0 520,0 240,300 0,360" fill="#e60012" opacity="0.16" />
    <polygon points="1440,0 1440,420 1120,160 1240,0" fill="#e60012" opacity="0.13" />
    <polygon points="0,900 0,560 360,900" fill="#b3000e" opacity="0.16" />
    <polygon points="1440,900 1040,900 1440,540" fill="#e60012" opacity="0.12" />
    <!-- thin slashes -->
    <polygon points="700,0 760,0 360,900 300,900" fill="#e60012" opacity="0.06" />
    <polygon points="1180,0 1210,0 880,900 850,900" fill="#ffffff" opacity="0.03" />
    <!-- outline stars -->
    <polygon class="star" points="1180,640 1206,712 1282,712 1221,757 1244,830 1180,786 1116,830 1139,757 1078,712 1154,712"
      fill="none" stroke="#e60012" stroke-width="3" opacity="0.25" />
    <polygon class="star" points="180,150 196,196 244,196 205,224 220,270 180,242 140,270 155,224 116,196 164,196"
      fill="none" stroke="#ffffff" stroke-width="2" opacity="0.12" />
  </svg>
  <div class="grain"></div>
  <div class="vignette"></div>
</div>

<style>
  .backdrop {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background:
      radial-gradient(120% 90% at 85% 8%, rgba(179, 0, 14, 0.28) 0%, transparent 45%),
      radial-gradient(120% 90% at 10% 100%, rgba(179, 0, 14, 0.22) 0%, transparent 50%),
      linear-gradient(160deg, #0c0506 0%, #060606 55%, #0a0306 100%);
  }

  .shards {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Ben-day dot grain across the whole field. */
  .grain {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(#000 1px, transparent 1.4px);
    background-size: 6px 6px;
    opacity: 0.5;
    mix-blend-mode: multiply;
  }

  /* Subtle darkening at the edges to focus the eye on content. */
  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 120% at 50% 40%, transparent 55%, rgba(0, 0, 0, 0.55) 100%);
  }
</style>
