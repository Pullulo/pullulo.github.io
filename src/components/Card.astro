---
/**
 * Angular content card (CLAUDE.md §3 — nothing is a plain rectangle).
 * Uses clip-path for a jagged corner; inner content stays upright.
 * In Phase 3 these are the staggerCards() targets (data-card).
 */
interface Props {
  title?: string;
  eyebrow?: string;
  /** Visual emphasis variant. */
  variant?: "default" | "accent";
  href?: string;
  /** Heading level for the card title (default 3). Use 2 where cards are the
   *  top-level content directly under the page <h1> so the outline doesn't skip. */
  headingLevel?: 2 | 3;
}
const { title, eyebrow, variant = "default", href, headingLevel = 3 } = Astro.props;
const Tag = href ? "a" : "article";
const Heading = `h${headingLevel}` as "h2" | "h3";
---

<Tag class:list={["card", variant]} href={href} data-card>
  <span class="corner" aria-hidden="true"></span>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  {title && <Heading class="title">{title}</Heading>}
  <div class="body"><slot /></div>
</Tag>

<style>
  .card {
    position: relative;
    display: block;
    background: var(--p5-gray-900);
    color: var(--p5-white);
    border: 2px solid var(--p5-white);
    padding: 1.5rem 1.6rem 1.6rem;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 18px), calc(100% - 18px) 100%, 0 100%);
    box-shadow: var(--shadow-hard);
    transition: transform 0.18s var(--ease-slam), border-color 0.18s, box-shadow 0.18s;
  }

  .card.accent {
    border-color: var(--p5-red);
    background: linear-gradient(135deg, #1d0307 0%, var(--p5-gray-900) 62%);
  }

  a.card:hover,
  a.card:focus-visible {
    transform: translate(-5px, -5px);
    border-color: var(--p5-yellow);
    box-shadow: var(--shadow-red);
    outline: none;
  }

  /* red corner notch flag */
  .corner {
    position: absolute;
    top: 0;
    right: 0;
    width: 0;
    height: 0;
    border-top: 26px solid var(--p5-red);
    border-left: 26px solid transparent;
  }

  .eyebrow {
    margin: 0 0 0.4rem;
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--p5-red-text); /* AA contrast on the dark card */
  }

  .title {
    margin: 0 0 0.6rem;
    font-size: clamp(1.3rem, 2.4vw, 1.7rem);
    color: var(--p5-white);
  }

  .body {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .body :global(p) {
    margin: 0 0 0.7rem;
  }

  .body :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
