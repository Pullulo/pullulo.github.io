---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Card from "../components/Card.astro";
import MaskEmblem from "../components/MaskEmblem.astro";
---

<BaseLayout title="Baron Li — Physics Researcher">
  <article class="home">
    <header class="hero">
      <div class="hero-text">
        <SectionHeading kicker="Profile" title="Baron Li" />
        <p class="role-line"><span>Physics Researcher</span></p>
        <p class="tagline">
          Particle detection · Fusion diagnostics · The philosophy of science.
        </p>
        <ul class="stats" aria-label="At a glance">
          <li><b>JINST</b><span>First-author paper</span></li>
          <li><b>170&nbsp;GHz</b><span>Waveguide notch filter</span></li>
          <li><b>LXe&nbsp;TPC</b><span>PET detector concept</span></li>
        </ul>
      </div>

      <figure class="hero-figure">
        <div class="frame">
          <img
            src="/profile-wide.jpg"
            width="1100"
            height="782"
            alt="Baron Li standing beside his 170 GHz waveguide notch-filter research poster at UC Davis"
          />
          <MaskEmblem class="figure-badge" size="84px" />
        </div>
        <figcaption>Beside the 170&nbsp;GHz ENOCH notch-filter poster · UC&nbsp;Davis</figcaption>
      </figure>
    </header>

    <div class="content">
      <section class="about panel" aria-labelledby="about-h">
        <h2 id="about-h" class="block-label"><span>About</span></h2>
        <p>
          High school student interested in experimental physics, particle detection, fusion
          diagnostics, and the philosophy of science. Research spans liquid xenon detectors for
          medical imaging, millimeter-wave diagnostics for fusion plasmas, and particle physics
          instrumentation. Also reads philosophy and enjoys questions about science, knowledge, and
          the nature of explanation.
        </p>
      </section>

      <section class="highlights" aria-labelledby="hl-h">
        <h2 id="hl-h" class="block-label"><span>Research Highlights</span></h2>
        <div class="grid">
          <Card variant="accent" eyebrow="Medical Imaging" title="Liquid Xenon PET Detector" headingLevel={2}>
            <p>
              Developed a novel liquid xenon time projection chamber concept for medical imaging.
              First-author publication in JINST.
            </p>
          </Card>
          <Card variant="accent" eyebrow="Plasma Physics" title="Fusion Plasma Diagnostics" headingLevel={2}>
            <p>
              Designed and tested microwave diagnostic components including a 170&nbsp;GHz waveguide
              notch filter for fusion plasma experiments.
            </p>
          </Card>
        </div>
      </section>

      <section class="recent" aria-labelledby="recent-h">
        <h2 id="recent-h" class="block-label"><span>Recent Publications</span></h2>
        <Card headingLevel={2} title="A New Concept of Liquid Xenon TPC for Medical Imaging" eyebrow="JINST · 2026">
          <p class="citation">Li, B., Ma, X., Ni, K. — JINST, Vol.&nbsp;21, Apr.&nbsp;2026, C04019.</p>
          <p class="doi">DOI: <a href="https://doi.org/10.1088/1748-0221/21/04/C04019" rel="noopener">10.1088/1748-0221/21/04/C04019</a></p>
          <p class="more"><a href="/publications">View all publications →</a></p>
        </Card>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .home {
    max-width: 1100px;
  }

  /* ---- Hero ---- */
  .hero {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    margin-bottom: 3rem;
  }

  .role-line {
    margin: 0 0 1rem;
    display: inline-block;
    background: var(--p5-black);
    color: var(--p5-yellow);
    border: 1.5px solid var(--p5-yellow);
    transform: skewX(var(--skew));
    padding: 0.2em 0.8em;
  }
  .role-line span {
    display: inline-block;
    transform: skewX(calc(-1 * var(--skew)));
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .tagline {
    margin: 0 0 1.5rem;
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.5;
    color: var(--p5-white);
    max-width: 40ch;
  }

  .stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .stats li {
    background: var(--p5-gray-900);
    border: 2px solid var(--p5-gray-600);
    border-left: 4px solid var(--p5-red);
    padding: 0.5rem 0.9rem;
    transform: skewX(var(--skew));
  }
  .stats b,
  .stats span {
    display: block;
    transform: skewX(calc(-1 * var(--skew)));
  }
  .stats b {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--p5-white);
    line-height: 1;
  }
  .stats span {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--p5-gray-400);
    margin-top: 0.2rem;
  }

  .hero-figure {
    margin: 0;
  }
  .frame {
    position: relative;
    transform: skewX(var(--skew-soft));
  }
  .frame img {
    width: 100%;
    border: 3px solid var(--p5-white);
    box-shadow: var(--shadow-hard-lg);
    filter: contrast(1.05) saturate(0.92);
  }
  .figure-badge {
    position: absolute;
    left: -22px;
    bottom: -22px;
    transform: skewX(calc(-1 * var(--skew-soft))) rotate(-8deg);
  }
  .hero-figure figcaption {
    margin-top: 1.1rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--p5-gray-400);
    border-left: 3px solid var(--p5-red);
    padding-left: 0.6rem;
  }

  /* ---- Content ---- */
  .content {
    max-width: 75ch;
  }

  .block-label {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--p5-white);
    background: var(--p5-red);
    transform: skewX(var(--skew));
    padding: 0.15em 0.75em;
    margin: 0 0 1.1rem;
    box-shadow: var(--shadow-hard);
  }
  .block-label span {
    display: inline-block;
    transform: skewX(calc(-1 * var(--skew)));
  }

  section + section {
    margin-top: 2.75rem;
  }

  .about {
    padding: 1.6rem 1.7rem;
  }
  .about .block-label {
    margin-top: -2.6rem; /* let the label straddle the panel's top edge */
    margin-left: -0.4rem;
  }
  .about p {
    margin: 0;
    line-height: 1.75;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.4rem;
  }

  .citation {
    margin: 0 0 0.4rem;
    line-height: 1.6;
  }
  .doi {
    margin: 0 0 0.8rem;
    font-size: 0.9rem;
  }
  .more {
    margin: 0;
    font-family: var(--font-display);
    letter-spacing: 0.04em;
  }
  .more a {
    color: var(--p5-yellow);
  }

  @media (max-width: 820px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
